# Copy this file to ocr/.env and fill in your Aliyun credentials.
# The Aliyun OCR Python SDK uses AccessKey credentials, not a single bearer token.

ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# Optional if you are using STS temporary credentials.
ALIBABA_CLOUD_SECURITY_TOKEN=

# Optional override. Default is ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# Aliyun market seal OCR uses AppKey + AppSecret digest signing.
ALIYUN_MARKET_SEAL_APP_KEY=your_market_app_key
ALIYUN_MARKET_SEAL_APP_SECRET=your_market_app_secret
ALIYUN_MARKET_SEAL_ENDPOINT=https://stamp.market.alicloudapi.com
ALIYUN_MARKET_SEAL_PATH=/api/predict/ocr_official_seal
